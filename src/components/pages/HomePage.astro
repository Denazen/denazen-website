---
import WaitlistForm from '../WaitlistForm.astro';
import type { Lang } from '../../i18n/config';
import { localizeAsset } from '../../i18n/assets';
import type enContent from '../../content/pages/index.en';

interface Props {
  lang: Lang;
  content: typeof enContent;
}

const { lang, content: c } = Astro.props;
const img = (p: string) => localizeAsset(p, lang);
---
<!-- Hero -->
<section class="hero">
  <div class="container">
    <div class="hero-grid">
      <div class="hero-text">
        <h1 class="hero-headline">
          <span class="hero-headline-public">{c.hero.headlinePublic}</span>
          <span class="hero-headline-private">{c.hero.headlinePrivate}</span>
        </h1>
        <p class="lead">{c.hero.lead}</p>
        <p class="hero-encrypted">
          <svg class="icon-lock-closed" viewBox="0 0 512 512" fill="#38A169" aria-hidden="true">
            <path d="M368 192h-16v-80a96 96 0 10-192 0v80h-16a64.07 64.07 0 00-64 64v176a64.07 64.07 0 0064 64h224a64.07 64.07 0 0064-64V256a64.07 64.07 0 00-64-64zm-48 0H192v-80a64 64 0 11128 0z"/>
          </svg>
          <span>{c.hero.encrypted}</span>
        </p>
        <WaitlistForm lang={lang} id="waitlist" buttonLabel={c.hero.waitlistButton} note={c.hero.waitlistNote} />
      </div>
      <div class="hero-visual">
        <img class="hero-phone hero-phone-back" src={img('/images/screenshots/hero-public.webp')} alt={c.hero.imageAltPublic} width="560" height="1111" />
        <img class="hero-phone hero-phone-front" src={img('/images/screenshots/hero-private.webp')} alt={c.hero.imageAltPrivate} width="560" height="1111" />
      </div>
    </div>
  </div>
</section>

<!-- Why Denazen? -->
<section class="section-tint">
  <div class="container">
    <div class="section-heading">
      <h2>{c.whyDenazen.heading}</h2>
      <p>{c.whyDenazen.body}</p>
    </div>
  </div>
</section>

<!-- Public when you want -->
<section>
  <div class="container">
    <div class="info-grid reversed">
      <div class="info-text">
        <h2>{c.publicSection.heading}</h2>
        {c.publicSection.paragraphs.map((p) => <p>{p}</p>)}
      </div>
      <div class="info-visual">
        <img src={img('/images/screenshots/feed-public.webp')} alt={c.publicSection.imageAlt} width="560" height="1111" />
      </div>
    </div>
  </div>
</section>

<!-- Private when it matters -->
<section class="section-tint">
  <div class="container">
    <div class="info-grid">
      <div class="info-text">
        <h2>{c.privateSection.heading}</h2>
        {c.privateSection.paragraphs.map((p) => <p>{p}</p>)}
      </div>
      <div class="info-visual">
        <img src={img('/images/screenshots/private-network.webp')} alt={c.privateSection.imageAlt} width="560" height="1111" />
      </div>
    </div>
  </div>
</section>

<!-- Circles -->
<section>
  <div class="container">
    <div class="info-grid reversed">
      <div class="info-text">
        <h2>{c.circlesSection.heading}</h2>
        {c.circlesSection.paragraphs.map((p) => <p>{p}</p>)}
      </div>
      <div class="info-visual">
        <img src={img('/images/screenshots/circles.webp')} alt={c.circlesSection.imageAlt} width="560" height="1111" />
      </div>
    </div>
  </div>
</section>

<!-- Feature grid 2x2 -->
<section class="section-tint">
  <div class="container">
    <div class="section-heading">
      <h2>{c.features.heading}</h2>
      <p>{c.features.subheading}</p>
    </div>
    <div class="feature-grid">
      <article class="card">
        <svg class="card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="11" width="18" height="11" rx="2"></rect>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
        </svg>
        <h3>{c.features.cards[0].title}</h3>
        <p>{c.features.cards[0].body}</p>
      </article>

      <article class="card">
        <svg class="card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="9" cy="8" r="4"></circle>
          <path d="M3 21v-1a6 6 0 0 1 6-6h0a6 6 0 0 1 6 6v1"></path>
          <circle cx="17" cy="10" r="3"></circle>
          <path d="M15 21v-1a4 4 0 0 1 4-4h0"></path>
        </svg>
        <h3>{c.features.cards[1].title}</h3>
        <p>{c.features.cards[1].body}</p>
      </article>

      <article class="card">
        <svg class="card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="9"></circle>
          <path d="M3 12h18"></path>
          <path d="M12 3c2.5 3 3.5 6 3.5 9s-1 6-3.5 9"></path>
          <path d="M12 3c-2.5 3-3.5 6-3.5 9s1 6 3.5 9"></path>
        </svg>
        <h3>{c.features.cards[2].title}</h3>
        <p>{c.features.cards[2].body}</p>
      </article>

      <article class="card">
        <svg class="card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
        </svg>
        <h3>{c.features.cards[3].title}</h3>
        <p>{c.features.cards[3].body}</p>
      </article>
    </div>
  </div>
</section>

<!-- No ads / no trackers -->
<section>
  <div class="container">
    <div class="info-grid">
      <div class="info-text">
        <h2>{c.noAds.heading}</h2>
        {c.noAds.paragraphs.map((p) => <p>{p}</p>)}
      </div>
      <div class="info-visual">
        <ul class="denial-typo" role="list" aria-label={c.noAds.listAria}>
          {c.noAds.listItems.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- Secondary waitlist CTA -->
<section class="section-dark">
  <div class="container">
    <div class="section-heading">
      <h2>{c.ctaSection.heading}</h2>
      <p>{c.ctaSection.body}</p>
    </div>
    <div style="display:flex; justify-content:center;">
      <div>
        <WaitlistForm lang={lang} id="waitlist-footer" buttonLabel={c.ctaSection.waitlistButton} note={c.ctaSection.waitlistNote} />
      </div>
    </div>
  </div>
</section>
